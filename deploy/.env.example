# Copy this file to .env in the same directory, fill in your values, then
# run `docker compose up -d --build`. See ../docs/self-hosting.md for the
# full walkthrough. This file is read both by docker-compose.yml (for the
# ${STREAMWALL_DOMAIN} / ${STREAMWALL_ACME_EMAIL} substitutions) and, via
# `env_file:`, injected directly into the control-server container.

# --- Caddy / TLS -------------------------------------------------------

# Public domain to request a Let's Encrypt certificate for and reverse-proxy
# to the control server. Must already point (A/AAAA record) at this host,
# with ports 80 and 443 reachable from the internet -- Caddy needs port 80
# for the ACME HTTP-01 challenge.
STREAMWALL_DOMAIN=wall.example.com

# Email Caddy registers with Let's Encrypt/ZeroSSL, used only for
# certificate-expiry/problem notices.
STREAMWALL_ACME_EMAIL=you@example.com

# --- streamwall-control-server ------------------------------------------

# Public base URL of the control server. Must use https:// -- this drives
# secure-cookie and Content-Security-Policy behaviour (see
# packages/streamwall-control-server/README.md). Keep the domain in sync
# with STREAMWALL_DOMAIN above; do not add a port here.
STREAMWALL_CONTROL_URL=https://wall.example.com

# The port the server listens on inside its container. Always set this
# explicitly. STREAMWALL_CONTROL_URL above intentionally has no port (a
# bare https://domain), and the server does not fill in the scheme's
# conventional port (443) when one is missing from the URL -- so leaving
# this unset would make it listen on an unusable port. Must match the
# `reverse_proxy control-server:<port>` target in Caddyfile (default 3000).
STREAMWALL_CONTROL_PORT=3000

# Optional: tune abuse protection (defaults shown). See
# packages/streamwall-control-server/README.md for the full list, and note
# the rate-limiting caveat in docs/self-hosting.md when running behind a
# reverse proxy.
#STREAMWALL_RATE_LIMIT_MAX=100
#STREAMWALL_AUTH_RATE_LIMIT_MAX=10
#STREAMWALL_RATE_LIMIT_WINDOW=1 minute
#STREAMWALL_WS_MSG_RATE=100
#STREAMWALL_WS_MSG_BURST=1000

# Optional: crash reporting to your own Sentry project (off by default).
#STREAMWALL_SENTRY_ENABLED=true
#STREAMWALL_SENTRY_DSN=

# Optional: where auth tokens are stored inside the container. Defaults to
# /data/storage.json, which is already on the persistent `control-server-data`
# volume declared in docker-compose.yml -- only override if you know you
# need a different path on that same volume.
#DB_PATH=/data/storage.json
