{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "changelog-path": "CHANGELOG.md",
  "include-component-in-tag": false,
  "include-v-in-tag": true,
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "changelog-sections": [
    { "type": "feat", "section": "Added" },
    { "type": "fix", "section": "Fixed" },
    { "type": "perf", "section": "Performance" },
    { "type": "refactor", "section": "Changed" },
    { "type": "docs", "section": "Documentation" },
    { "type": "revert", "section": "Reverted" },
    { "type": "build", "section": "Build", "hidden": true },
    { "type": "chore", "section": "Miscellaneous", "hidden": true },
    { "type": "ci", "section": "CI", "hidden": true },
    { "type": "style", "section": "Styling", "hidden": true },
    { "type": "test", "section": "Tests", "hidden": true }
  ],
  "packages": {
    ".": {
      "package-name": "streamwall",
      "extra-files": [
        {
          "type": "json",
          "path": "packages/streamwall/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "packages/streamwall-control-server/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "package-lock.json",
          "jsonpath": "$.packages['packages/streamwall'].version"
        },
        {
          "type": "json",
          "path": "package-lock.json",
          "jsonpath": "$.packages['packages/streamwall-control-server'].version"
        }
      ]
    }
  }
}
